# ============================================================
# VoxIntel Frontend — Production Environment Variables
# Copy to .env.production and fill in your deployed API origin.
# Not needed in dev — the CRA dev server proxy (see package.json
# "proxy" field) handles routing /api calls to the local backend.
# ============================================================

# Base URL of the deployed Node/Express API, including the /api prefix.
REACT_APP_API_URL=https://api.example.com/api
