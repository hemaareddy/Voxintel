# ============================================================
# VoxIntel Server Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Node environment
NODE_ENV=development
PORT=5000

# MongoDB connection string
# Local:  mongodb://localhost:27017/voxintel
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/voxintel
MONGO_URI=mongodb://localhost:27017/voxintel

# JWT secret — change this to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_me

# JWT expiry
JWT_EXPIRES_IN=7d

# Python NLP service URL
PYTHON_SERVICE_URL=http://localhost:5001

# Max file upload size (in MB)
MAX_FILE_SIZE_MB=10

# Bcrypt salt rounds
BCRYPT_ROUNDS=10

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
